---
import BaseLayout from "../layouts/BaseLayout.astro";
import Link from "../components/Link.astro";
import HeadingLink from "../components/HeadingLink.astro";
---

<BaseLayout pageTitle="Michael Mandic">
  <p
    class="text-2xl text-green-5 dark:text-green-3 tracking-tight mb-6 font-normal text-balance"
  >
    Software engineer based in Belgrade, citizen of Serbia and the EU
  </p>
  <div class="flex flex-wrap gap-6 mb-6">
    <Link
      href="https://www.linkedin.com/in/michael-mandic/"
      text="LinkedIn"
      target="_blank"
    />
    <Link
      href="https://github.com/michaelmandic"
      text="GitHub"
      target="_blank"
    />
  </div>
  <p class="paragraph">
    Hi, I'm Michael Mandic, a software engineering student @ University of
    Belgrade, School of Electrical Engineering.
  </p>
  <p class="paragraph">
    I'm passionate about computer science and full-stack development and eager
    to contribute to real-world projects and gain industry experience.
  </p>
  <h2 id="skills-and-tech-stack" class="heading group">
    <HeadingLink idName="skills-and-tech-stack" />Skills & Tech Stack
  </h2>
  <p class="paragraph">Under construction.</p>
  <h2 id="get-in-touch" class="heading group">
    <HeadingLink idName="get-in-touch" />Get in Touch
  </h2>
  <p class="paragraph">
    You can reach me at <a href="mailto:hey@builtbymike.dev" class="link"
      >hey@builtbymike.dev</a
    >, <a href="mailto:mihajlomandic27@gmail.com" class="link"
      >mihajlomandic27@gmail.com</a
    > or via <a
      href="https://www.linkedin.com/in/michael-mandic/"
      class="link"
      target="_blank">LinkedIn</a
    >.
  </p>
</BaseLayout>
