    <p class="paragraph">
      The page you're trying to access does not exist, please check if you made
      a typo or go to the home page.
    </p>
    <pre
      class="font-mono leading-6 text-green-6 dark:text-green-2 text-xl">
           ___
         />    フ
         | _  _| 
        /`ミ_xノ 
      /       |
     / ヽ     ﾉ
    │   |  | |
／￣|   |  | |
|(￣ヽ__ヽ_)__)
＼二)
    </pre>
  </div>
</BaseLayout>
