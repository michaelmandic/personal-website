---
const { idName = "" } = Astro.props;
---

<a
  href={`#${idName}`}
  class="absolute md:inline hidden top-1/2 translate-x-0 right-full pr-2 -translate-y-1/2 text-green-5 dark:text-green-3 opacity-0 group-hover:opacity-25 hover:opacity-100 transition-all font-light hover:font-extrabold"
  aria-label="Link to this heading">#</a
>
