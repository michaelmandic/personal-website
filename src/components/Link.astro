---
import RightArrow from "../assets/rightarrow.svg";

const {
  href = "#",
  text,
  target: targetName = "_self",
  class: className,
  ...rest
} = Astro.props;
---

<a
  href={href}
  class={`inline-flex items-center group gap-1 ${className}`}
  {...rest}
  target={targetName}
>
  <span
    class="group-hover:text-green-5 font-normal text-green-7 dark:text-green-1 text-lg transform dark:group-hover:text-green-3 transition-all group-hover:font-extrabold"
    >{text}</span
  >
  <RightArrow
    width={16}
    height={16}
    class="text-green-6 transform transition-all dark:text-green-2 group-hover:translate-x-1 group-hover:scale-115 group-hover:text-green-5 dark:group-hover:text-green-3"
  />
</a>
